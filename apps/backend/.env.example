# ── Backend configuration ────────────────────────────────────────────────────
# Copy to .env for local dev. In production these are supplied per-tenant by
# docker-compose.tenant.yml (see ONBOARDING.md).

# Required
DATABASE_URL=postgresql://postgres:password@localhost:5433/whatsapp_system
JWT_SECRET=use-a-long-random-string-min-32-chars-in-production
PORT=4000
FRONTEND_URL=http://localhost:3000

# WhatsApp provider
WHATSAPP_PROVIDER=baileys
# Per-instance WhatsApp auth folder (lets multiple instances coexist on one host)
WHATSAPP_SESSION_PATH=auth_info_baileys
# true = skip the 15-day new-number warm-up ramp (set when connecting an
# already-trusted, long-lived number). Default false = safe ramp for new numbers.
WHATSAPP_ESTABLISHED=false
# Warm-up ENFORCEMENT is opt-in. Off by default so the dashboard can show warm-up
# data without ever throttling an existing number. Set true ONLY for a genuinely
# fresh number you want capped through the 15-day ramp.
WARMUP_ENFORCE=false

# Developer super-account — provisioned/kept as SUPER_ADMIN on every boot.
# Leave blank to disable. In production the password must be >= 12 chars.
DEV_SUPERUSER_EMAIL=
DEV_SUPERUSER_PASSWORD=
DEV_SUPERUSER_NAME=Developer

# Business owner — created (create-only) on first boot of a fresh instance.
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_NAME=

# Redis — REQUIRED in production (broadcasts + automation-flow queues).
# In the Docker stack this points at the bundled `redis` service
# (redis://redis:6379). Locally, leave blank to fall back to localhost.
REDIS_URL=

# ── Media storage ─────────────────────────────────────────────────────────────
# In production you must EITHER configure S3-compatible storage below, OR opt into
# durable local-disk storage. For a single self-hosted instance, local storage on
# a persistent volume is perfectly fine (the Docker stack sets this to true):
ALLOW_LOCAL_STORAGE=false
# S3 / Cloudflare R2 / MinIO. When S3_BUCKET is set, uploads go to object storage
# instead of local disk (recommended for ephemeral/cloud hosts). Leave blank for
# local storage.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# Optional AI bot (Groq)
GROQ_API_KEY=
GROQ_MODEL=
