# ── Frontend configuration ───────────────────────────────────────────────────
# Copy to .env.local for local dev. NEXT_PUBLIC_* are baked at BUILD time.

# Where the browser reaches the backend. In production this is the tenant's
# public origin (the reverse proxy routes /api and /socket.io to the backend).
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# NextAuth (runtime)
NEXTAUTH_SECRET=use-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
